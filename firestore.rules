rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Lectures: anyone can read published, only admin can write
    match /lectures/{lectureId} {
      allow read: if resource.data.published == true;
      allow read, write: if request.auth != null && request.auth.token.email == "YOUR_ADMIN_EMAIL@example.com";
    }
    
    // Progress: open read/write for MVP (students aren't Firebase authed)
    match /progress/{progressId} {
      allow read, write: if true;
    }
    
    // FCM Tokens: anyone can create, admin can read/delete
    match /fcmTokens/{tokenId} {
      allow create: if true;
      allow read, delete: if request.auth != null && request.auth.token.email == "YOUR_ADMIN_EMAIL@example.com";
    }
  }
}
